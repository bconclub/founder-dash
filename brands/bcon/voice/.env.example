# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# WhatsApp (Meta Cloud API)
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
WA_TEMPLATE_NAME=bcon_followup

# Admin approval gate
# WhatsApp number to receive task notifications (with country code, e.g. 919876543210)
ADMIN_NOTIFY_PHONE=
# 'notify' = messages go out, admin gets a copy on WhatsApp
# 'approve' = messages held until manually approved, admin gets preview
APPROVAL_MODE=notify
